# Copy this to .env.production.local for local production builds,
# OR set REACT_APP_API_BASE as an Environment Variable in Vercel dashboard.
#
# Replace with your actual EC2 public IP or DNS name.
# Make sure port 8080 is open in your EC2 Security Group (inbound TCP 8080).
REACT_APP_API_BASE=http://<your-ec2-public-ip>:8080/api
